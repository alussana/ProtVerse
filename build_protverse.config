    url_proteomeHD = 'https://www.proteomehd.net/download_file/S1'
    url_pc13_intact = 'https://www.pathwaycommons.org/archives/PC2/v12/PathwayCommons12.intact.hgnc.sif.gz'
    url_pc13_biogrid = 'https://www.pathwaycommons.org/archives/PC2/v12/PathwayCommons12.biogrid.hgnc.sif.gz'
