cleanup = false

workDir = '/hps/nobackup/petsalaki/users/alussana/nf_workDir_protverse_build_protverse'

dag.overwrite = true

process {

    container = 'file://envs/protverse.sif'
    executor = 'slurm'
    queueSize = 64
    memory = '8G'
    errorStrategy = 'retry'
    time = '4h'

    withLabel: 'lightning' {

        clusterOptions = "--gres=gpu:a100:1 --gpus=a100:1"
        container = 'file://env/protverse_cuda.sif'
        containerOptions = '--nv'
        memory = '64G'
        time = '4h'
        cpus = 11
        errorStrategy = 'ignore'

    }

    withLabel: 'lightning_cpu' {

        container = 'file://env/protverse_cuda.sif'
        memory = '64G'
        time = '4h'
        cpus = 11

    }

}

executor {

    submitRateLimit = '10sec'
    executor.cpus = 1024

}

singularity {

    enabled = true
    autoMounts = true

}

env {

    out_dir = '/nfs/research/petsalaki/users/alussana/protverse'
    huggingface_cache_dir = '/nfs/research/petsalaki/users/alussana/.cache/huggingface'
    ptmdb_text_format = "${projectDir}/dataset/ptmdb/all_db.zip"
    ptmdb_imputed_h5 = "${projectDir}/dataset/ptmdb/genes_latent.h5ad"
    ubiquitination_data_source = "${projectDir}/dataset/ubiquitination/G2S1B_0.05_protein_pos_all_prot_mapping.csv"
    lopit2025_xlsx_path = "${projectDir}/dataset/lopit2025/1-s2.0-S1535947624001786-mmc1.xlsx"

}

params {

    url_human_proteome = 'https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/idmapping/by_organism/HUMAN_9606_idmapping.dat.gz'
